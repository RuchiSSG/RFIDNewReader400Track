    <script>
                            function loadChestRFID(groupId)
                            {
                                $.get('/RFID/GetChestRFIDByGroup', { groupId: groupId })
                                    .done(function (data) {

                                        console.log("Chest RFID Data:", data);

                                        let tbody = $('#chestTable tbody');
                                        tbody.empty();

                                        if (!data || data.length === 0) {
                                            tbody.append('<tr><td colspan="11">No Data</td></tr>');
                                            return;
                                        }

                            data.forEach(item => {
                            tbody.append(`
                                <tr data-rfid="${item.tagId}">
                                    <td>${item.chestNo}</td>
                                    <td>${item.tagId}</td>
                                    <td>${item.barcode}</td>
                                              <td class="lap-count text-muted">0</td>
                                              <td class="lap1 text-muted"></td>
                                              <td class="lap2 text-muted"></td>
                                              <td class="lap3 text-muted d-none"></td>
                                              <td class="lap4 text-muted d-none"></td>
                                              <td class="lap5 text-muted d-none"></td>
                                                      <td class="duration ${item.isCompleted ? 'text-success fw-bold' : ''}">
                                                ${item.duration ?? ''}
                                              </td>
                                                        <td class="single-time d-none"></td>
                                          <!--<td class="live-time text-muted">Waiting...</td>-->
                                </tr>
                            `);
                        });

                                    })
                                    .fail(function () {
                                        alert('Failed to load Chest RFID data');
                                    });
                     }




