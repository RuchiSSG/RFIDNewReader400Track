                                            function updateTable(data) {

            if (!data || data.length === 0) return;

            const eventName = $("#eventName").val();

            let maxLaps = 1;

            if (eventName === "1600 Meter Running") {
                maxLaps = 5;
            }
            else if (eventName === "800 Meter Running") {
                maxLaps = 3;
            }
            else {
                maxLaps = 1; // 100m etc.
            }

            const isSingleRace = (maxLaps === 1);

            /* =========================
               🔥 COLUMN VISIBILITY
            ==========================*/

            // Hide all lap columns first
                for (let i = 1; i <= 5; i++) {
            $(`.lap${i}-col`).addClass("d-none");
            $(`.lap${i}`).addClass("d-none");
        }

            $("#chestTable th.lap-col, #chestTable td.lap-count").hide();
            $("#chestTable th.duration-col, #chestTable td.duration").hide();
            $("#chestTable th.single-time-col, #chestTable td.single-time").hide();

            if (isSingleRace) {

                // Show only Final Time
                $("#chestTable th.single-time-col, #chestTable td.single-time").show();

            } else {

                // Show lap count + duration
                $("#chestTable th.lap-col, #chestTable td.lap-count").show();
                $("#chestTable th.duration-col, #chestTable td.duration").show();

                // Show required lap columns dynamically
                       for (let i = 1; i <= maxLaps; i++) {
            $(`.lap${i}-col`).removeClass("d-none");
            $(`.lap${i}`).removeClass("d-none");
        }
            }

            /* =========================
               🔥 UPDATE ROW DATA
            ==========================*/

            data.forEach(item => {

                const lapTimes = item.lapTimes || [];
                const lapCount = lapTimes.length;

                const $row = $(`#chestTable tr[data-rfid='${item.tagId}']`);
                if (!$row.length) return;

                const $lapCount = $row.find('.lap-count');
                const $duration = $row.find('.duration');
                const $singleTime = $row.find('.single-time');

                // Reset all lap cells first
                for (let i = 1; i <= 5; i++) {
                    $row.find(`.lap${i}`)
                        .removeClass('fw-bold text-success')
                        .addClass('text-muted')
                        .text('');
                }

                if (isSingleRace) {

                           if (item.duration) {

            $singleTime
                .removeClass('text-muted')
                .addClass('fw-bold text-success')
                .text(item.duration);

        }
        else if (item.currentDateTime) {

            $singleTime
                .removeClass('text-muted')
                .addClass('fw-bold text-success')
                .text(item.currentDateTime);
        }

                } else {

                    // Update lap count
                    $lapCount
                        .removeClass('text-muted')
                        .addClass('fw-bold')
                        .text(lapCount);

                    // Update lap cells dynamically
                    for (let i = 0; i < lapTimes.length; i++) {

                        const $lapCell = $row.find(`.lap${i + 1}`);

                        $lapCell
                            .removeClass('text-muted')
                            .addClass('fw-bold text-success')
                            .text(lapTimes[i]);
                    }

                    // Duration
                    if (item.duration) {
                        $duration
                            .removeClass('text-muted')
                            .addClass('fw-bold text-primary')
                            .text(item.duration);
                    }
                }

            });
        }

